# ---- Backend (api + worker) ----
# development | production. Production refuses to boot with AUTH_DEV_MODE=true.
ENV=development

DATABASE_URL=postgresql+psycopg://beacon:beacon@db:5432/beacon
REDIS_URL=redis://redis:6379/0

# Secret used to sign backend JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-real-secret

# GitHub OAuth app (used by frontend NextAuth; backend verifies the access
# token against the GitHub API). Callback URL:
#   http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Set to true to enable email/password-less dev sign-in (no GitHub needed).
# NEVER enable in production.
AUTH_DEV_MODE=true

# CORS: the exact origin of the frontend
FRONTEND_ORIGIN=http://localhost:3000

# Webhook rate limit (requests per minute per API key)
WEBHOOK_RATE_LIMIT_PER_MINUTE=30

# Email delivery for finished reports: none | resend | smtp
EMAIL_PROVIDER=none
EMAIL_FROM=beacon@example.com
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- Agent core (beacon/) ----
# API key for the Generator / Investigator / Reporter agents (Gemini via
# langchain-google-genai). Passed explicitly to the model, so this exact name
# is what the code reads. Optionally override the model with GEMINI_MODEL.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Per-agent overrides (cost tiering), falling back to GEMINI_MODEL.
# Recommended split from the model-comparison benchmark: strong model on the
# two single-shot calls, lite model on the call-heavy investigator loop.
# GENERATOR_MODEL=gemini-3.5-flash
# REPORTER_MODEL=gemini-3.5-flash
# INVESTIGATOR_MODEL=gemini-3.1-flash-lite

# ---- Frontend (web) ----
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=change-me-generate-a-real-secret
# Browser-facing API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side (inside docker network) API URL
API_URL_INTERNAL=http://api:8000
